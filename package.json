{
  "name": "vue-media-defer",
  "version": "1.0.1",
  "description": "A high-performance Vue 2/3 media lazy-loading component with AbortController support.",
  "type": "module",
  "main": "./dist/vue-media-defer.umd.js",
  "module": "./dist/vue-media-defer.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-media-defer.es.js",
      "require": "./dist/vue-media-defer.umd.js"
    },
    "./dist/vue-media-defer.css": "./dist/vue-media-defer.css",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src",
    "index.ts"
  ],
  "keywords": [
    "vue",
    "vue3",
    "vue2",
    "lazyload",
    "media",
    "image",
    "video",
    "intersection-observer"
  ],
  "author": "wonishi",
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "prepublishOnly": "npm run lint && npm run build",
    "release": "npx standard-version",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,html}\"",
    "postinstall": "node node_modules/vue-demi/bin/vue-demi-fix.js",
    "prepare": "husky install"
  },
  "dependencies": {
    "vue-demi": "^0.14.0"
  },
  "peerDependencies": {
    "@vue/composition-api": "^1.0.0-rc.1",
    "vue": "^2.0.0 || >=3.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.21.1",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^3.7.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,html}": [
      "prettier --write"
    ]
  }
}