{
  "name": "vue-media-defer",
  "version": "1.0.2",
  "description": "Universal Vue component for media lazy loading supporting Vue 2 & Vue 3",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/vue-media-defer.cjs",
  "module": "./dist/vue-media-defer.js",
  "unpkg": "./dist/vue-media-defer.iife.js",
  "jsdelivr": "./dist/vue-media-defer.iife.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue-media-defer.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue-media-defer.cjs"
      },
      "default": "./dist/vue-media-defer.umd.js"
    },
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src/**/*.{ts,vue}",
    "lint:fix": "eslint src/**/*.{ts,vue} --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,html}\"",
    "prepare": "husky install",
    "release": "np"
  },
  "dependencies": {
    "vue-demi": "latest"
  },
  "peerDependencies": {
    "vue": "^2.0.0 || >=3.0.0",
    "@vue/composition-api": "^1.0.0-rc.1"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "vue": "^3.4.27",
    "vite": "^5.2.12",
    "@vitejs/plugin-vue": "^5.0.4",
    "vite-plugin-dts": "^3.0.0",
    "terser": "^5.0.0",
    "typescript": "^5.4.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "prettier": "^3.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "np": "^9.0.0"
  },
  "lint-staged": {
    "*.{vue,ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "volta": {
    "node": "20.19.6"
  }
}